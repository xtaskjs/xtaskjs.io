{{> site-header viewer=viewer}}

<main class="spring-like-home admin-shell">
  <section class="section">
    <div class="hero-copy">
      <p class="eyebrow">{{t "auth.twoFactor.eyebrow"}}</p>
      <h1>{{t "auth.twoFactor.title" email=email}}</h1>
      <p>{{t "auth.twoFactor.subtitle"}}</p>
    </div>
  </section>

  <section class="section auth-page-grid">
    <article class="admin-card">
      <h2>{{t "auth.twoFactor.formTitle"}}</h2>
      {{#if hasError}}
        <p class="form-error">{{#if errorMessage}}{{errorMessage}}{{else}}{{t errorMessageKey email=email}}{{/if}}</p>
      {{/if}}
      {{#if infoMessageKey}}
        <p class="form-success">{{t infoMessageKey email=email}}</p>
      {{/if}}
      <form method="post" action="/login/verify" class="admin-form">
        <label for="code">{{t "auth.twoFactor.code"}}</label>
        <input id="code" name="code" type="text" inputmode="numeric" autocomplete="one-time-code" required />

        <button type="submit" class="cta-primary btn-full">{{t "auth.twoFactor.submit"}}</button>
      </form>

      <div class="auth-inline-actions">
        <form method="post" action="/login/verify/resend" class="auth-inline-form">
          <button type="submit" class="cta-secondary inline-btn">{{t "auth.twoFactor.resend"}}</button>
        </form>
        <a href="/login" class="cta-secondary inline-btn">{{t "auth.twoFactor.startOver"}}</a>
      </div>
    </article>

    <article class="feature-card auth-aside-card">
      <h2>{{t "auth.twoFactor.securityTitle"}}</h2>
      <p>{{t "auth.twoFactor.securityBody"}}</p>
    </article>
  </section>
</main>