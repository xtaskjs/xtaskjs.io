{{> site-header viewer=viewer}}

<main class="spring-like-home admin-shell">
  <section class="section">
    <div class="hero-copy">
      <p class="eyebrow">{{t "auth.resetPassword.eyebrow"}}</p>
      <h1>{{t "auth.resetPassword.title"}}</h1>
      <p>{{t "auth.resetPassword.subtitle"}}</p>
    </div>
  </section>

  <section class="section auth-page-grid">
    <article class="admin-card">
      <h2>{{t "auth.resetPassword.formTitle"}}</h2>
      {{#if hasError}}
        <p class="form-error">{{#if errorMessage}}{{errorMessage}}{{else}}{{t errorMessageKey}}{{/if}}</p>
      {{/if}}
      <form method="post" action="/reset-password" class="admin-form">
        <label for="email">{{t "auth.resetPassword.email"}}</label>
        <input id="email" name="email" type="email" autocomplete="email" required value="{{email}}" />

        <label for="code">{{t "auth.resetPassword.code"}}</label>
        <input id="code" name="code" type="text" inputmode="numeric" autocomplete="one-time-code" required value="{{code}}" />

        <label for="password">{{t "auth.resetPassword.password"}}</label>
        <input id="password" name="password" type="password" autocomplete="new-password" required />

        <label for="confirmPassword">{{t "auth.resetPassword.confirmPassword"}}</label>
        <input id="confirmPassword" name="confirmPassword" type="password" autocomplete="new-password" required />

        <button type="submit" class="cta-primary btn-full">{{t "auth.resetPassword.submit"}}</button>
      </form>

      <div class="auth-inline-actions">
        <a href="/login" class="cta-secondary inline-btn">{{t "auth.resetPassword.backToLogin"}}</a>
      </div>
    </article>

    <article class="feature-card auth-aside-card">
      <h2>{{t "auth.resetPassword.rulesTitle"}}</h2>
      <p>{{t "auth.resetPassword.rulesBody"}}</p>
    </article>
  </section>
</main>