<div class="sticky-top">
  <div class="announcement-bar">
    <p>
      {{t "site.header.announcement"}}
    </p>
  </div>

  <header class="site-header">
    <div class="nav-wrap">
      <a href="/" class="brand-link" aria-label="xTaskjs home">
        <img src="/logo.svg" alt="xTaskjs logo" class="nav-logo" />
      </a>
      <nav class="main-nav" aria-label="Main">
        <a href="/#why">{{t "site.header.why"}}</a>
        <a href="/#learn">{{t "site.header.learn"}}</a>
        <a href="/documentation">{{t "site.header.documentation"}}</a>
        <a href="/news">{{t "site.header.news"}}</a>
      </nav>
      <div class="nav-actions desktop-only">
        <div class="language-switcher" aria-label="{{t "site.header.languageLabel"}}">
          {{#each localeOptions}}
            <a href="{{href}}" class="language-chip{{#if isCurrent}} language-chip-active{{/if}}" hreflang="{{locale}}">{{shortLabel}}</a>
          {{/each}}
        </div>
        <button
          type="button"
          class="icon-button theme-toggle"
          data-theme-toggle
          data-theme-label-dark="{{t "site.header.themeToDark"}}"
          data-theme-label-light="{{t "site.header.themeToLight"}}"
          aria-pressed="false"
          aria-label="{{t "site.header.themeToDark"}}"
          title="{{t "site.header.themeToDark"}}"
        >
          <span class="theme-icon theme-icon-sun" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M12 4a1 1 0 0 1 1 1v1.2a1 1 0 1 1-2 0V5a1 1 0 0 1 1-1Zm0 12.6a4.6 4.6 0 1 0 0-9.2 4.6 4.6 0 0 0 0 9.2Zm0 3.2a1 1 0 0 1 1 1V22a1 1 0 1 1-2 0v-1.2a1 1 0 0 1 1-1Zm7-8.6h1.2a1 1 0 1 1 0 2H19a1 1 0 1 1 0-2ZM3.8 11h1.2a1 1 0 1 1 0 2H3.8a1 1 0 1 1 0-2Zm12.34-4.93 0.85-0.85a1 1 0 0 1 1.42 1.42l-0.85 0.85a1 1 0 0 1-1.42-1.42Zm-10.28 10.28 0.85-0.85a1 1 0 1 1 1.42 1.42l-0.85 0.85a1 1 0 0 1-1.42-1.42Zm11.13 1.7a1 1 0 0 1 0-1.42l0.85-0.85a1 1 0 0 1 1.42 1.42l-0.85 0.85a1 1 0 0 1-1.42 0Zm-10.28-10.28a1 1 0 0 1 0-1.42l0.85-0.85a1 1 0 1 1 1.42 1.42l-0.85 0.85a1 1 0 0 1-1.42 0Z" />
            </svg>
          </span>
          <span class="theme-icon theme-icon-moon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M14.5 3.2a1 1 0 0 1 .92 1.39 7.95 7.95 0 0 0 9.99 10.02 1 1 0 0 1 1.28 1.2A9.98 9.98 0 1 1 13.3 2.05a1 1 0 0 1 1.2 1.15Z" transform="translate(-2 -1)" />
            </svg>
          </span>
        </button>
        <a
          class="icon-button nav-github"
          href="https://github.com/xtaskjs/xtask"
          target="_blank"
          rel="noreferrer"
          aria-label="{{t "site.header.github"}}"
          title="GitHub"
        >
          <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.73.5 12.18c0 5.16 3.3 9.53 7.88 11.07.58.11.8-.26.8-.58 0-.29-.01-1.04-.02-2.04-3.2.71-3.88-1.57-3.88-1.57-.52-1.35-1.28-1.71-1.28-1.71-1.05-.74.08-.73.08-.73 1.16.08 1.77 1.21 1.77 1.21 1.03 1.8 2.7 1.28 3.36.98.1-.76.4-1.28.73-1.58-2.56-.3-5.24-1.3-5.24-5.8 0-1.28.45-2.33 1.18-3.15-.12-.3-.51-1.5.11-3.12 0 0 .97-.31 3.17 1.2a10.8 10.8 0 0 1 5.76 0c2.2-1.51 3.17-1.2 3.17-1.2.62 1.62.23 2.82.11 3.12.73.82 1.18 1.87 1.18 3.15 0 4.51-2.69 5.5-5.26 5.8.41.36.78 1.08.78 2.18 0 1.58-.01 2.85-.01 3.24 0 .32.21.7.81.58 4.57-1.55 7.86-5.91 7.86-11.07C23.5 5.73 18.35.5 12 .5Z" />
          </svg>
        </a>
        {{#if viewer}}
          <span class="nav-user-chip">{{viewer.displayName}}</span>
          <a href="{{viewer.accountHref}}" class="cta-secondary nav-auth-link">{{#if viewer.isAdmin}}{{t "site.header.adminPanel"}}{{else}}{{t "site.header.dashboard"}}{{/if}}</a>
          <form method="post" action="/logout" class="inline-form">
            <button type="submit" class="cta-secondary nav-auth-btn">{{t "site.header.logout"}}</button>
          </form>
        {{else}}
          <a href="/login" class="cta-secondary nav-auth-link">{{t "site.header.login"}}</a>
          <a href="/register" class="github-btn nav-register-btn">{{t "site.header.register"}}</a>
        {{/if}}
      </div>
      <button class="menu-toggle" id="menu-toggle" data-label-open="{{t "site.header.menuOpen"}}" data-label-close="{{t "site.header.menuClose"}}" aria-expanded="false" aria-controls="mobile-menu" aria-label="{{t "site.header.menuOpen"}}">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <div class="mobile-backdrop" id="mobile-backdrop" hidden></div>
  <nav class="mobile-nav-panel" id="mobile-menu" aria-label="Mobile" hidden>
    <a href="/#why">{{t "site.header.why"}}</a>
    <a href="/#learn">{{t "site.header.learn"}}</a>
    <a href="/documentation">{{t "site.header.documentation"}}</a>
    <a href="/news">{{t "site.header.news"}}</a>
    <div class="language-switcher mobile-language-switcher" aria-label="{{t "site.header.languageLabel"}}">
      {{#each localeOptions}}
        <a href="{{href}}" class="language-chip{{#if isCurrent}} language-chip-active{{/if}}" hreflang="{{locale}}">{{label}}</a>
      {{/each}}
    </div>
    <button
      type="button"
      class="icon-button theme-toggle mobile-theme-toggle"
      data-theme-toggle
      data-theme-label-dark="{{t "site.header.themeToDark"}}"
      data-theme-label-light="{{t "site.header.themeToLight"}}"
      aria-pressed="false"
      aria-label="{{t "site.header.themeToDark"}}"
      title="{{t "site.header.themeToDark"}}"
    >
      <span class="theme-icon theme-icon-sun" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M12 4a1 1 0 0 1 1 1v1.2a1 1 0 1 1-2 0V5a1 1 0 0 1 1-1Zm0 12.6a4.6 4.6 0 1 0 0-9.2 4.6 4.6 0 0 0 0 9.2Zm0 3.2a1 1 0 0 1 1 1V22a1 1 0 1 1-2 0v-1.2a1 1 0 0 1 1-1Zm7-8.6h1.2a1 1 0 1 1 0 2H19a1 1 0 1 1 0-2ZM3.8 11h1.2a1 1 0 1 1 0 2H3.8a1 1 0 1 1 0-2Zm12.34-4.93 0.85-0.85a1 1 0 0 1 1.42 1.42l-0.85 0.85a1 1 0 0 1-1.42-1.42Zm-10.28 10.28 0.85-0.85a1 1 0 1 1 1.42 1.42l-0.85 0.85a1 1 0 0 1-1.42-1.42Zm11.13 1.7a1 1 0 0 1 0-1.42l0.85-0.85a1 1 0 0 1 1.42 1.42l-0.85 0.85a1 1 0 0 1-1.42 0Zm-10.28-10.28a1 1 0 0 1 0-1.42l0.85-0.85a1 1 0 1 1 1.42 1.42l-0.85 0.85a1 1 0 0 1-1.42 0Z" />
        </svg>
      </span>
      <span class="theme-icon theme-icon-moon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M14.5 3.2a1 1 0 0 1 .92 1.39 7.95 7.95 0 0 0 9.99 10.02 1 1 0 0 1 1.28 1.2A9.98 9.98 0 1 1 13.3 2.05a1 1 0 0 1 1.2 1.15Z" transform="translate(-2 -1)" />
        </svg>
      </span>
    </button>
    {{#if viewer}}
      <span class="nav-user-chip mobile-user-chip">{{viewer.displayName}}</span>
      <a href="{{viewer.accountHref}}" class="cta-secondary nav-auth-link">{{#if viewer.isAdmin}}{{t "site.header.adminPanel"}}{{else}}{{t "site.header.dashboard"}}{{/if}}</a>
      <form method="post" action="/logout" class="mobile-auth-form">
        <button type="submit" class="cta-secondary nav-auth-btn">{{t "site.header.logout"}}</button>
      </form>
    {{else}}
      <a href="/login" class="cta-secondary nav-auth-link">{{t "site.header.login"}}</a>
      <a href="/register" class="github-btn nav-register-btn">{{t "site.header.register"}}</a>
    {{/if}}
    <a
      class="icon-button nav-github mobile-github-link"
      href="https://github.com/xtaskjs/xtask"
      target="_blank"
      rel="noreferrer"
      aria-label="{{t "site.header.github"}}"
      title="GitHub"
    >
      <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
        <path d="M12 .5C5.65.5.5 5.73.5 12.18c0 5.16 3.3 9.53 7.88 11.07.58.11.8-.26.8-.58 0-.29-.01-1.04-.02-2.04-3.2.71-3.88-1.57-3.88-1.57-.52-1.35-1.28-1.71-1.28-1.71-1.05-.74.08-.73.08-.73 1.16.08 1.77 1.21 1.77 1.21 1.03 1.8 2.7 1.28 3.36.98.1-.76.4-1.28.73-1.58-2.56-.3-5.24-1.3-5.24-5.8 0-1.28.45-2.33 1.18-3.15-.12-.3-.51-1.5.11-3.12 0 0 .97-.31 3.17 1.2a10.8 10.8 0 0 1 5.76 0c2.2-1.51 3.17-1.2 3.17-1.2.62 1.62.23 2.82.11 3.12.73.82 1.18 1.87 1.18 3.15 0 4.51-2.69 5.5-5.26 5.8.41.36.78 1.08.78 2.18 0 1.58-.01 2.85-.01 3.24 0 .32.21.7.81.58 4.57-1.55 7.86-5.91 7.86-11.07C23.5 5.73 18.35.5 12 .5Z" />
      </svg>
    </a>
  </nav>
</div>
