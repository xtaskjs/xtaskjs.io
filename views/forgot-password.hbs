{{> site-header viewer=viewer}}

<main class="spring-like-home admin-shell">
  <section class="section">
    <div class="hero-copy">
      <p class="eyebrow">{{t "auth.forgotPassword.eyebrow"}}</p>
      <h1>{{t "auth.forgotPassword.title"}}</h1>
      <p>{{t "auth.forgotPassword.subtitle"}}</p>
    </div>
  </section>

  <section class="section auth-page-grid">
    <article class="admin-card">
      <h2>{{t "auth.forgotPassword.formTitle"}}</h2>
      {{#if hasError}}
        <p class="form-error">{{#if errorMessage}}{{errorMessage}}{{else}}{{t errorMessageKey}}{{/if}}</p>
      {{/if}}
      {{#if infoMessageKey}}
        <p class="form-success">{{t infoMessageKey}}</p>
      {{/if}}
      <form method="post" action="/forgot-password" class="admin-form">
        <label for="email">{{t "auth.forgotPassword.email"}}</label>
        <input id="email" name="email" type="email" autocomplete="email" required value="{{email}}" />

        <button type="submit" class="cta-primary btn-full">{{t "auth.forgotPassword.submit"}}</button>
      </form>
      <div class="auth-inline-actions">
        <a href="/login" class="cta-secondary inline-btn">{{t "auth.forgotPassword.backToLogin"}}</a>
      </div>
    </article>

    <article class="feature-card auth-aside-card">
      <h2>{{t "auth.forgotPassword.afterTitle"}}</h2>
      <p>{{t "auth.forgotPassword.afterBody"}}</p>
    </article>
  </section>
</main>