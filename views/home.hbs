{{> site-header viewer=viewer}}

<main class="spring-like-home astra-home">
  <section class="astra-hero" id="why">
    <div class="astra-hero__copy">
      <p class="eyebrow">{{t "site.home.eyebrow"}}</p>
      <h1>{{t "site.home.title"}}</h1>
      <p class="astra-hero__lead">{{t "site.home.tagline"}}</p>
      <p class="astra-hero__body">{{t "site.home.stack"}}</p>
      <div class="hero-cta">
        <a href="#learn" class="cta-primary">{{t "site.home.quickStart"}}</a>
        <a href="https://github.com/xtaskjs/xtask" target="_blank" rel="noreferrer" class="cta-secondary">{{t "site.home.exploreGithub"}}</a>
      </div>
      <div class="astra-hero__signals" aria-label="{{t "site.home.signalsAria"}}">
        <span class="stack astra-signal-chip">{{t "site.home.signals.one"}}</span>
        <span class="stack astra-signal-chip">{{t "site.home.signals.two"}}</span>
        <span class="stack astra-signal-chip">{{t "site.home.signals.three"}}</span>
      </div>
    </div>
    <aside class="astra-hero__panel">
      <p class="eyebrow">{{t "site.home.productionReady"}}</p>
      <h2>{{t "site.home.panelTitle"}}</h2>
      <p class="astra-hero__panel-body">{{t "site.home.panelBody"}}</p>
      <ul class="astra-checklist">
        <li>{{t "site.home.productionItems.one"}}</li>
        <li>{{t "site.home.productionItems.two"}}</li>
        <li>{{t "site.home.productionItems.three"}}</li>
      </ul>
      <div class="astra-mini-grid">
        <article class="astra-mini-card">
          <strong>{{t "site.home.metrics.one.value"}}</strong>
          <span>{{t "site.home.metrics.one.label"}}</span>
        </article>
        <article class="astra-mini-card">
          <strong>{{t "site.home.metrics.two.value"}}</strong>
          <span>{{t "site.home.metrics.two.label"}}</span>
        </article>
        <article class="astra-mini-card">
          <strong>{{t "site.home.metrics.three.value"}}</strong>
          <span>{{t "site.home.metrics.three.label"}}</span>
        </article>
        <article class="astra-mini-card">
          <strong>{{t "site.home.metrics.four.value"}}</strong>
          <span>{{t "site.home.metrics.four.label"}}</span>
        </article>
      </div>
    </aside>
  </section>

  <section class="section astra-section" id="learn">
    <div class="astra-section-head">
      <p class="eyebrow">{{t "site.home.learnEyebrow"}}</p>
      <h2>{{t "site.home.learnTitle"}}</h2>
      <p>{{t "site.home.learnSubtitle"}}</p>
    </div>
    <div class="astra-learn-grid">
      <article class="feature-card astra-feature-card">
        <p class="astra-card-kicker">{{t "site.home.guidesKicker"}}</p>
        <h3>{{t "site.home.guidesTitle"}}</h3>
        <p>{{t "site.home.guidesBody"}}</p>
        <a href="/documentation/architecture#quick-start" class="cta-secondary inline-btn">{{t "site.home.guidesAction"}}</a>
      </article>
      <article class="feature-card astra-feature-card">
        <p class="astra-card-kicker">{{t "site.home.referenceKicker"}}</p>
        <h3>{{t "site.home.referenceTitle"}}</h3>
        <p>{{t "site.home.referenceBody"}}</p>
        <a href="/documentation/packages" class="cta-secondary inline-btn">{{t "site.home.referenceAction"}}</a>
      </article>
      <article class="feature-card astra-feature-card">
        <p class="astra-card-kicker">{{t "site.home.examplesKicker"}}</p>
        <h3>{{t "site.home.examplesTitle"}}</h3>
        <p>{{t "site.home.examplesBody"}}</p>
        <a href="/documentation/samples" class="cta-secondary inline-btn">{{t "site.home.examplesAction"}}</a>
      </article>
    </div>
  </section>

  <section class="section astra-workbench">
    <div class="astra-workbench__content">
      <div class="astra-section-head astra-section-head--compact">
        <p class="eyebrow">{{t "site.home.workflowEyebrow"}}</p>
        <h2>{{t "site.home.workflowTitle"}}</h2>
        <p>{{t "site.home.workflowBody"}}</p>
      </div>
      <div class="astra-timeline">
        <article class="astra-timeline-card">
          <span class="astra-step-index">01</span>
          <h3>{{t "site.home.workflowSteps.one.title"}}</h3>
          <p>{{t "site.home.workflowSteps.one.body"}}</p>
        </article>
        <article class="astra-timeline-card">
          <span class="astra-step-index">02</span>
          <h3>{{t "site.home.workflowSteps.two.title"}}</h3>
          <p>{{t "site.home.workflowSteps.two.body"}}</p>
        </article>
        <article class="astra-timeline-card">
          <span class="astra-step-index">03</span>
          <h3>{{t "site.home.workflowSteps.three.title"}}</h3>
          <p>{{t "site.home.workflowSteps.three.body"}}</p>
        </article>
      </div>
    </div>
    <aside class="feature-card astra-spotlight-card">
      <p class="eyebrow">{{t "site.home.spotlightEyebrow"}}</p>
      <h3>{{t "site.home.spotlightTitle"}}</h3>
      <p>{{t "site.home.spotlightBody"}}</p>
      <ul class="astra-spotlight-list">
        <li>{{t "site.home.spotlightItems.one"}}</li>
        <li>{{t "site.home.spotlightItems.two"}}</li>
        <li>{{t "site.home.spotlightItems.three"}}</li>
      </ul>
      <a href="/documentation" class="cta-primary inline-btn">{{t "site.home.openDocumentationHub"}}</a>
    </aside>
  </section>

  <section class="section astra-section" id="projects">
    <div class="astra-section-head astra-section-head--compact">
      <p class="eyebrow">{{t "site.home.projectsEyebrow"}}</p>
      <h2>{{t "site.home.projectsTitle"}}</h2>
      <p>{{t "site.home.projectsSubtitle"}}</p>
    </div>
    <div class="project-grid astra-project-grid">
      {{#each projectPackages}}
        <article class="project-card project-package-card astra-project-card">
          <div class="project-card-heading astra-project-card__heading">
            <div>
              <p class="astra-card-kicker">npm package</p>
              <h3><a href="{{npmUrl}}" target="_blank" rel="noreferrer">{{name}}</a></h3>
            </div>
            <span class="stack project-version-chip">v{{latestVersion}}</span>
          </div>
          <p>{{description}}</p>
          <p class="project-published-at">
            {{#if publishedAt}}
              {{t "site.home.publishedOnNpm" date=(formatDateTime publishedAt)}}
            {{else}}
              {{t "site.home.publishedOnNpm" date=(t "site.home.npmUnavailable")}}
            {{/if}}
          </p>
        </article>
      {{/each}}
    </div>
    <div class="astra-section-actions">
      <a href="/documentation/packages" class="cta-primary inline-btn">{{t "site.home.referenceAction"}}</a>
      <a href="/documentation" class="cta-secondary inline-btn">{{t "site.home.openDocumentationHub"}}</a>
    </div>
  </section>

  <section class="section split astra-community-grid" id="community">
    <article class="feature-card astra-community-card">
      <p class="astra-card-kicker">{{t "site.home.communityKicker"}}</p>
      <h3>{{t "site.home.communityTitle"}}</h3>
      <p>{{t "site.home.communityBody"}}</p>
    </article>
    <article class="feature-card astra-community-card" id="support">
      <p class="astra-card-kicker">{{t "site.home.supportKicker"}}</p>
      <h3>{{t "site.home.supportTitle"}}</h3>
      <p>{{t "site.home.supportBody"}}</p>
    </article>
  </section>

  <section class="section astra-section" id="news">
    <div class="astra-section-head astra-section-head--compact">
      <p class="eyebrow">{{t "site.home.newsEyebrow"}}</p>
      <h2>{{t "site.home.latestNewsTitle"}}</h2>
      <p>{{t "site.home.latestNewsSubtitle"}}</p>
    </div>
    <div class="news-feed compact astra-news-grid">
      {{#if latestNews.length}}
        {{#each latestNews}}
          <article class="news-card astra-news-card">
            {{#if imageUrl}}
              <img src="{{imageUrl}}" alt="{{title}}" class="news-card-image astra-news-card__image" />
            {{/if}}
            <header class="news-card-header">
              <h3>{{title}}</h3>
              <p class="news-meta">{{formatDateTime createdAt}}</p>
            </header>
            <p class="news-summary">{{summary}}</p>
          </article>
        {{/each}}
      {{else}}
        <article class="feature-card astra-news-empty-card">
          <h3>{{t "site.home.latestNewsEmptyTitle"}}</h3>
          <p>{{t "site.home.latestNewsEmptyBody"}}</p>
        </article>
      {{/if}}
    </div>
    <a href="/news" class="cta-secondary inline-btn">{{t "site.home.openFullNews"}}</a>
  </section>

  <section class="astra-final-cta">
    <div>
      <p class="eyebrow">{{t "site.home.finalEyebrow"}}</p>
      <h2>{{t "site.home.finalTitle"}}</h2>
      <p>{{t "site.home.finalBody"}}</p>
    </div>
    <div class="hero-cta astra-final-cta__actions">
      <a href="/documentation/architecture#quick-start" class="cta-primary">{{t "site.home.finalPrimary"}}</a>
      <a href="/documentation/samples" class="cta-secondary">{{t "site.home.finalSecondary"}}</a>
    </div>
  </section>
</main>

{{> site-footer}}
