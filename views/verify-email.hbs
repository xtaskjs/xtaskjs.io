{{> site-header viewer=viewer}}

<main class="spring-like-home admin-shell">
  <section class="section">
    <div class="hero-copy">
      <p class="eyebrow">{{t "auth.verifyEmail.eyebrow"}}</p>
      <h1>{{t "auth.verifyEmail.title"}}</h1>
      <p>{{t "auth.verifyEmail.subtitle"}}</p>
    </div>
  </section>

  <section class="section auth-page-grid">
    <article class="admin-card">
      <h2>{{t "auth.verifyEmail.formTitle"}}</h2>
      {{#if hasError}}
        <p class="form-error">{{#if errorMessage}}{{errorMessage}}{{else}}{{t errorMessageKey email=email}}{{/if}}</p>
      {{/if}}
      {{#if infoMessageKey}}
        <p class="form-success">{{t infoMessageKey email=email}}</p>
      {{/if}}
      <form method="post" action="/verify-email" class="admin-form">
        <label for="email">{{t "auth.verifyEmail.email"}}</label>
        <input id="email" name="email" type="email" autocomplete="email" required value="{{email}}" />

        <label for="code">{{t "auth.verifyEmail.code"}}</label>
        <input id="code" name="code" type="text" inputmode="numeric" autocomplete="one-time-code" required value="{{code}}" />

        <button type="submit" class="cta-primary btn-full">{{t "auth.verifyEmail.submit"}}</button>
      </form>

      <div class="auth-inline-actions">
        <form method="post" action="/verify-email/resend" class="auth-inline-form">
          <input type="hidden" name="email" value="{{email}}" />
          <button type="submit" class="cta-secondary inline-btn">{{t "auth.verifyEmail.resend"}}</button>
        </form>
        <a href="/login" class="cta-secondary inline-btn">{{t "auth.verifyEmail.backToLogin"}}</a>
      </div>
    </article>

    <article class="feature-card auth-aside-card">
      <h2>{{t "auth.verifyEmail.nextTitle"}}</h2>
      <p>{{t "auth.verifyEmail.nextBody"}}</p>
      <p class="auth-note">{{t "auth.verifyEmail.nextNote"}}</p>
    </article>
  </section>
</main>