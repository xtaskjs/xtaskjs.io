{{> site-header viewer=viewer}}

<main class="spring-like-home admin-shell">
  <section class="section">
    <div class="hero-copy">
      <p class="eyebrow">{{t "auth.dashboard.eyebrow"}}</p>
      <h1>{{t "auth.dashboard.title" name=user.fullName}}</h1>
      <p>{{t "auth.dashboard.subtitle"}}</p>
    </div>
  </section>

  <section class="section dashboard-grid">
    <article class="admin-card dashboard-card">
      <h2>{{t "auth.dashboard.detailsTitle"}}</h2>
      <dl class="profile-grid">
        <div>
          <dt>{{t "auth.dashboard.fullName"}}</dt>
          <dd>{{user.fullName}}</dd>
        </div>
        <div>
          <dt>{{t "auth.dashboard.username"}}</dt>
          <dd>{{user.username}}</dd>
        </div>
        <div>
          <dt>{{t "auth.dashboard.email"}}</dt>
          <dd>{{user.email}}</dd>
        </div>
        <div>
          <dt>{{t "auth.dashboard.receiveNewsUpdates"}}</dt>
          <dd>{{#if user.receiveNewsUpdates}}{{t "auth.dashboard.enabled"}}{{else}}{{t "auth.dashboard.disabled"}}{{/if}}</dd>
        </div>
        <div>
          <dt>{{t "auth.dashboard.newsletterSubscription"}}</dt>
          <dd>{{#if user.newsletterSubscribed}}{{t "auth.dashboard.subscribed"}}{{else}}{{t "auth.dashboard.notSubscribed"}}{{/if}}</dd>
        </div>
        <div>
          <dt>{{t "auth.dashboard.role"}}</dt>
          <dd>{{#if (eq user.role "admin")}}{{t "auth.dashboard.roleAdmin"}}{{else}}{{t "auth.dashboard.roleUser"}}{{/if}}</dd>
        </div>
        <div>
          <dt>{{t "auth.dashboard.status"}}</dt>
          <dd>{{#if user.isActive}}{{t "auth.dashboard.active"}}{{else}}{{t "auth.dashboard.inactive"}}{{/if}}</dd>
        </div>
        <div>
          <dt>{{t "auth.dashboard.emailVerification"}}</dt>
          <dd>{{#if user.emailVerified}}{{t "auth.dashboard.verified"}}{{else}}{{t "auth.dashboard.pending"}}{{/if}}</dd>
        </div>
        <div>
          <dt>{{t "auth.dashboard.joined"}}</dt>
          <dd>{{formatDateTime user.createdAt}}</dd>
        </div>
        <div>
          <dt>{{t "auth.dashboard.updated"}}</dt>
          <dd>{{formatDateTime user.updatedAt}}</dd>
        </div>
      </dl>
    </article>

    <article class="admin-card dashboard-card">
      <h2>{{t "auth.dashboard.preferencesTitle"}}</h2>
      {{#if preferencesUpdated}}
        <p class="form-success">{{t "auth.dashboard.preferencesUpdated"}}</p>
      {{/if}}
      <p class="auth-note">{{t "auth.dashboard.preferencesIntro"}}</p>
      <form method="post" action="/dashboard/newsletter" class="admin-form dashboard-preferences-form">
        <label class="checkbox-row" for="newsletterSubscribed">
          <input
            id="newsletterSubscribed"
            name="newsletterSubscribed"
            type="checkbox"
            {{#if user.newsletterSubscribed}}checked{{/if}}
          />
          <span class="checkbox-row-copy">
            <span>{{t "auth.dashboard.newsletterToggleLabel"}}</span>
            <span class="checkbox-row-hint">{{t "auth.dashboard.newsletterToggleHint"}}</span>
          </span>
        </label>
        <button type="submit" class="cta-primary">{{t "auth.dashboard.savePreferences"}}</button>
      </form>
    </article>

    <article class="feature-card dashboard-card">
      <h2>{{t "auth.dashboard.actionsTitle"}}</h2>
      <ul class="docs-list">
        <li>{{t "auth.dashboard.actionItems.one"}}</li>
        <li>{{t "auth.dashboard.actionItems.two"}}</li>
        <li>{{t "auth.dashboard.actionItems.three"}}</li>
        <li>{{t "auth.dashboard.actionItems.four"}}</li>
      </ul>
    </article>
  </section>
</main>
