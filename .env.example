PORT=3000
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=xtaskjs
POSTGRES_USER=xtask
POSTGRES_PASSWORD=xtask
REDIS_URL=redis://127.0.0.1:6379

CACHE_NAMESPACE=xtaskjs.io
DOCS_CACHE_TTL=15m
DOCS_HTTP_CACHE_MAX_AGE=5m

SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123!
# Optional: use a bcrypt hash instead of ADMIN_PASSWORD
# ADMIN_PASSWORD_HASH=$2b$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public app URL used in email links
PUBLIC_URL=http://127.0.0.1:3000

# Optional Docker compose port mapping, for example 443:3000 when HTTPS is enabled
APP_PORT_MAPPING=80:3000

# Optional Docker mount path that contains your TLS files
SSL_CERTS_DIR=../certificado_xtaskjs.io

# Optional HTTPS / TLS configuration
SSL_ENABLED=false
SSL_KEY_PATH=
SSL_CERT_PATH=
SSL_CA_PATH=

# Mailer configuration
MAIL_FROM=hello@xtaskjs.dev
MAIL_NOTIFICATIONS_FROM=alerts@xtaskjs.dev
MAIL_SUPPORT_TO=support@xtaskjs.dev
MAIL_NOTIFICATIONS_TO=ops@xtaskjs.dev

# Delivery provider for the default mail transport: json, mailtrap, or smtp
MAIL_TRANSPORT_PROVIDER=json

# Optional: override the notifications transport provider separately
MAIL_NOTIFICATIONS_TRANSPORT_PROVIDER=json

# Optional: Mailtrap account configuration
MAILTRAP_SMTP_USER=
MAILTRAP_SMTP_PASS=
MAILTRAP_SMTP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_SMTP_PORT=2525
MAILTRAP_SMTP_SECURE=false

# Optional: generic SMTP account configuration
MAIL_SMTP_USER=
MAIL_SMTP_PASS=
MAIL_SMTP_HOST=smtp.example.com
MAIL_SMTP_PORT=587
MAIL_SMTP_SECURE=false
