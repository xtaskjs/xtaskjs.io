PORT=3000
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=xtaskjs
POSTGRES_USER=xtask
POSTGRES_PASSWORD=xtask
REDIS_URL=redis://127.0.0.1:6379

CACHE_NAMESPACE=xtaskjs.io
DOCS_CACHE_TTL=15m
DOCS_HTTP_CACHE_MAX_AGE=5m

SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123!
# Optional: use a bcrypt hash instead of ADMIN_PASSWORD
# ADMIN_PASSWORD_HASH=$2b$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public app URL used in email links
PUBLIC_URL=http://127.0.0.1:3000

# Mailer configuration
MAIL_FROM=hello@xtaskjs.dev
MAIL_NOTIFICATIONS_FROM=alerts@xtaskjs.dev
MAIL_SUPPORT_TO=support@xtaskjs.dev
MAIL_NOTIFICATIONS_TO=ops@xtaskjs.dev

# Optional: Mailtrap / SMTP sandbox configuration
MAILTRAP_SMTP_USER=
MAILTRAP_SMTP_PASS=
MAILTRAP_SMTP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_SMTP_PORT=2525
MAILTRAP_SMTP_SECURE=false
